<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    SidebarView.fxml
    Reusable sidebar navigation panel. Loaded via fx:include in AppShellView.
    Controller: com.coit20258.drs.controller.SidebarController
-->
<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.coit20258.drs.controller.SidebarController"
    styleClass="sidebar">

    <!-- ── Logo ─────────────────────────────────────────────────── -->
    <VBox styleClass="sidebar-logo-section" spacing="3">
        <Label text="🛡" styleClass="sidebar-logo-icon"/>
        <Label text="DRS Enhanced"         styleClass="sidebar-logo-title"/>
        <Label text="Disaster Response System" styleClass="sidebar-logo-subtitle"/>
    </VBox>

    <!-- ── Nav section label ────────────────────────────────────── -->
    <Label text="NAVIGATION" styleClass="nav-section-label"/>

    <!-- ── Nav items ────────────────────────────────────────────── -->
    <VBox VBox.vgrow="ALWAYS">

        <Button fx:id="navDashboard"
                text="📊   Priority Dashboard"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavDashboard"/>

        <Button fx:id="navReports"
                text="🚨   Disaster Reports"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavReports"/>

        <Button fx:id="navAssessments"
                text="📋   Assessments"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavAssessments"/>

        <Button fx:id="navDepartments"
                text="🏢   Departments"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavDepartments"/>

        <Button fx:id="navEvacuation"
                text="🗺   Evacuation Zones"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavEvacuation"/>

        <Button fx:id="navResources"
                text="📦   Resources"
                styleClass="nav-item"
                maxWidth="Infinity"
                onAction="#handleNavResources"/>

    </VBox>

    <!-- ── User info + logout ────────────────────────────────────── -->
    <VBox styleClass="sidebar-footer" spacing="2">
        <Label fx:id="navUserName"  text="Loading…" styleClass="sidebar-user-name"/>
        <Label fx:id="navUserRole"  text=""          styleClass="sidebar-user-role"/>
        <Label fx:id="navUserEmail" text=""          styleClass="sidebar-user-email"/>
        <Button text="⬅   Sign Out"
                styleClass="btn-logout"
                maxWidth="Infinity"
                onAction="#handleLogout"/>
    </VBox>

</VBox>