<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    styleClass="root-pane"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.coit20258.drs.controller.LoginController">

    <!-- ═══════════════════════════════════════════════════════════════
         HEADER
    ════════════════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="14">
            <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>

            <!-- Shield icon + branding -->
            <Label text="🛡" style="-fx-font-size:24px;"/>
            <VBox spacing="2" alignment="CENTER_LEFT">
                <Label text="Disaster Response System" styleClass="header-title"/>
                <Label text="Emergency Coordination Platform" styleClass="header-subtitle"/>
            </VBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Status indicator -->
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="● SYSTEM ONLINE" style="-fx-text-fill:#22c55e; -fx-font-size:11px; -fx-font-weight:bold;"/>
                <Label fx:id="systemTimeLabel" text="" styleClass="header-subtitle"/>
            </VBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════════
         CENTRE — login card, vertically and horizontally centred
    ════════════════════════════════════════════════════════════════ -->
    <center>
        <StackPane styleClass="main-area">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

            <VBox alignment="CENTER" spacing="0">

                <!-- Emergency banner above the card -->
                <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 18 0;">
                    <Label text="⚠" style="-fx-text-fill:#c0392b; -fx-font-size:18px;"/>
                    <Label text="Authorised personnel only — all access is audited"
                           style="-fx-text-fill:#6b7280; -fx-font-size:12px; -fx-font-style:italic;"/>
                </HBox>

                <!-- ─── Login card ─── -->
                <VBox styleClass="form-panel"
                      minWidth="400" maxWidth="440"
                      spacing="0">

                    <!-- Card header -->
                    <VBox styleClass="form-header" spacing="4">
                        <padding><Insets top="22" right="28" bottom="22" left="28"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="🔐" style="-fx-font-size:20px;"/>
                            <VBox spacing="2">
                                <Label text="Sign In" styleClass="form-title"/>
                                <Label text="Enter your credentials to continue"
                                       styleClass="section-subtitle"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Card body -->
                    <VBox styleClass="form-body" spacing="18">
                        <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>

                        <!-- Username -->
                        <VBox spacing="6">
                            <Label text="Username" styleClass="field-label"/>
                            <TextField
                                fx:id="usernameField"
                                styleClass="field-input"
                                promptText="Enter your username"
                                onAction="#handleLogin"/>
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="6">
                            <Label text="Password" styleClass="field-label"/>
                            <PasswordField
                                fx:id="passwordField"
                                styleClass="field-input"
                                promptText="Enter your password"
                                onAction="#handleLogin"/>
                        </VBox>

                        <!-- Feedback label (hidden until needed) -->
                        <Label
                            fx:id="feedbackLabel"
                            styleClass="validation-label"
                            wrapText="true"
                            managed="false"
                            visible="false"/>

                        <!-- Sign In button -->
                        <Button
                            fx:id="loginButton"
                            text="Sign In"
                            styleClass="btn-primary"
                            maxWidth="Infinity"
                            defaultButton="true"
                            onAction="#handleLogin"/>

                        <Separator/>

                        <!-- Register link row -->
                        <HBox alignment="CENTER" spacing="8">
                            <Label text="Don't have an account?"
                                   styleClass="section-subtitle"/>
                            <Button
                                text="Create Account"
                                styleClass="btn-secondary"
                                onAction="#handleGoToRegister"/>
                        </HBox>

                    </VBox><!-- /card body -->
                </VBox><!-- /login card -->
            </VBox>
        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════════
         FOOTER
    ════════════════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="footer-bar" alignment="CENTER" spacing="16">
            <padding><Insets top="10" bottom="10"/></padding>
            <Label text="© 2026 Disaster Response System" styleClass="footer-label"/>
            <Label text="|" styleClass="footer-label"/>
            <Label text="v1.0 — DRS-Enhanced" styleClass="footer-label"/>
        </HBox>
    </bottom>

</BorderPane>
