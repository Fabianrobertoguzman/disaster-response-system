<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    DisasterReportFormView.fxml
    Content view — loaded into AppShellView's contentArea.
    No sidebar or footer (those live in the shell).
    Controller: com.coit20258.drs.controller.DisasterReportFormController
-->
<VBox
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.coit20258.drs.controller.DisasterReportFormController">

    <!-- ── Content header with breadcrumb ───────────────────────── -->
    <HBox styleClass="content-header" alignment="CENTER_LEFT" spacing="12">
        <Button text="← Back to Reports"
                styleClass="btn-secondary"
                onAction="#handleCancel"/>
        <Separator orientation="VERTICAL"
                   style="-fx-padding:0 4 0 4;"/>
        <VBox spacing="0">
            <Label text="New Disaster Report" styleClass="content-header-title"/>
            <Label text="Complete all required fields and submit."
                   styleClass="content-header-subtitle"/>
        </VBox>
    </HBox>

    <!-- ── Scrollable form body ─────────────────────────────────── -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane"
                hbarPolicy="NEVER" VBox.vgrow="ALWAYS">

        <VBox styleClass="content-body" spacing="24">

            <!-- Reporter info card (read-only — set from session) -->
            <VBox styleClass="summary-card" spacing="0">

                <HBox style="-fx-padding:14 20 14 20;
                             -fx-border-color:transparent transparent #e2e8f0 transparent;
                             -fx-border-width:0 0 1 0;"
                      alignment="CENTER_LEFT" spacing="10">
                    <Label text="👤" style="-fx-font-size:15px;"/>
                    <Label text="Reporting As" styleClass="card-title"/>
                </HBox>

                <HBox style="-fx-padding:16 20 16 20;" spacing="40">
                    <VBox spacing="3">
                        <Label text="NAME"  styleClass="summary-label"/>
                        <Label fx:id="reporterNameLabel" text="" styleClass="summary-value"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="ROLE"  styleClass="summary-label"/>
                        <Label fx:id="reporterRoleLabel" text="" styleClass="summary-value"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="EMAIL" styleClass="summary-label"/>
                        <Label fx:id="reporterEmailLabel" text="" styleClass="summary-value"/>
                    </VBox>
                </HBox>

            </VBox>

            <!-- Main form card -->
            <VBox styleClass="form-panel" spacing="0">

                <HBox styleClass="form-header" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="16" right="24" bottom="16" left="24"/>
                    </padding>
                    <Label text="🚨" style="-fx-font-size:16px; -fx-padding:0 10 0 0;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Incident Details"   styleClass="form-title"/>
                        <Label text="Fields marked * are required"
                               styleClass="section-subtitle"/>
                    </VBox>
                </HBox>

                <VBox styleClass="form-body" spacing="20">
                    <padding>
                        <Insets top="24" right="28" bottom="28" left="28"/>
                    </padding>

                    <!-- Type + Severity -->
                    <HBox spacing="20">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Disaster Type *" styleClass="field-label"/>
                            <ComboBox fx:id="disasterTypeCombo"
                                      styleClass="field-combo"
                                      promptText="Select disaster type"
                                      maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Severity Level *" styleClass="field-label"/>
                            <ComboBox fx:id="severityCombo"
                                      styleClass="field-combo"
                                      promptText="Select severity"
                                      maxWidth="Infinity"/>
                        </VBox>
                    </HBox>

                    <!-- Location -->
                    <VBox spacing="6">
                        <Label text="Affected Location *" styleClass="field-label"/>
                        <TextField fx:id="locationField"
                                   styleClass="field-input"
                                   promptText="e.g.  Brisbane CBD, Queensland"/>
                        <Label fx:id="locationError" styleClass="field-hint"
                               style="-fx-text-fill:#b91c1c;"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Description -->
                    <VBox spacing="6">
                        <Label text="Description *" styleClass="field-label"/>
                        <TextArea fx:id="descriptionArea"
                                  styleClass="field-textarea"
                                  promptText="Describe the event — people affected, active hazards, immediate needs…"
                                  prefRowCount="5"
                                  wrapText="true"/>
                        <Label fx:id="descriptionError" styleClass="field-hint"
                               style="-fx-text-fill:#b91c1c;"
                               visible="false" managed="false"/>
                    </VBox>

                    <!-- Validation banner -->
                    <Label fx:id="validationLabel"
                           styleClass="validation-label"
                           wrapText="true"
                           managed="false" visible="false"/>

                    <!-- Actions -->
                    <HBox spacing="12" alignment="CENTER_RIGHT"
                          style="-fx-padding:8 0 0 0;">
                        <Button text="Clear Form"
                                styleClass="btn-secondary"
                                onAction="#handleClear"/>
                        <Button fx:id="submitButton"
                                text="Submit Report"
                                styleClass="btn-primary"
                                defaultButton="true"
                                onAction="#handleSubmit"/>
                    </HBox>

                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>